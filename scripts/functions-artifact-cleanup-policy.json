{
  "cleanupPolicies": {
    "delete-all-function-artifacts": {
      "id": "delete-all-function-artifacts",
      "action": "DELETE",
      "condition": {
        "tagState": "ANY"
      }
    },
    "keep-one-function-artifact": {
      "id": "keep-one-function-artifact",
      "action": "KEEP",
      "mostRecentVersions": {
        "keepCount": 1
      }
    }
  },
  "cleanupPolicyDryRun": false
}
