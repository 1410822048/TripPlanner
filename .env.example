VITE_FIREBASE_API_KEY=your-api-key
# Development can use your Firebase Hosting auth domain. Production on
# Cloudflare Pages should use the app host (for example
# tripmate-2wg.pages.dev) so /__/auth/* stays same-origin via the Pages
# Function proxy.
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
VITE_USE_EMULATOR=false
# Optional: Sentry DSN (https://sentry.io → project settings → Client Keys).
# Leave empty to disable telemetry. Production builds without a DSN log a
# warning to console.
VITE_SENTRY_DSN=
# Cloudflare Worker base URL — serves /ocr, /expense-create, /expense-update,
# /cascade-trip-delete, /cascade-member. See workers/ocr/src/index.ts for the
# full route table.
#
# Behaviour when unset depends on the endpoint class:
#   - Read-only OCR (/ocr)         → falls back to the production worker
#                                    URL (Gemini extraction, no Firestore
#                                    writes; cost / rate-limit pollution
#                                    is the only downside)
#   - MUTATING endpoints (the rest) → requireWorkerWriteBase() throws.
#                                    This is intentional: a preview /
#                                    staging deploy without this env set
#                                    would otherwise route admin-SDK
#                                    writes against the production
#                                    Firestore via the production service
#                                    account.
#
# The legacy VITE_OCR_API_URL is still honoured as an OCR-only fallback
# for back-compat, but is NOT consulted for write endpoints.
VITE_WORKER_BASE_URL=
