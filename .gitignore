# ─── Logs ──────────────────────────────────────────────────────
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Dependencies & build output ───────────────────────────────
node_modules
dist
dist-ssr
firebase-functions/lib
*.local

# ─── Build caches ──────────────────────────────────────────────
*.tsbuildinfo
.vite/
.eslintcache

# ─── Env files (keep .env.example as the committed template) ──
.env
.env.local
.env.*.local
.env.production
.env.development

# ─── Firebase service-account credentials ─────────────────────
# Generated keys MUST NOT be committed — they bypass rules and
# grant admin access. Used locally only to feed the OCR worker's
# FIREBASE_SERVICE_ACCOUNT secret via `wrangler secret put`.
*-firebase-adminsdk-*.json
*service-account*.json
# GCP-console key downloads use <project>-<keyId>.json (no "firebase-adminsdk"
# in the name), so the pattern above misses them — match those too.
tripplanner-80a4f-*.json

# ─── Firebase CLI artefacts ────────────────────────────────────
.firebase/
firebase-debug.log*
firestore-debug.log*
database-debug.log*
ui-debug.log*
pubsub-debug.log*

# ─── Firestore data exports (backup target) ────────────────────
/backups/

# ─── Local-only source assets ─────────────────────────────────
# Master artwork (source PNG/SVG) consumed by scripts/generate-icons.mjs
# to produce the committed public/*.png variants. Kept out of git
# because the master is multi-MB and only changes when artwork is
# redesigned — contributors don't need it to build.
/assets/

# ─── Husky internals (keep .husky/pre-commit, ignore the shim) ─
.husky/_/

# ─── Claude Code workspace state (agent memory, session cache) ─
.claude/

# ─── GitNexus generated agent doc ─────────────────────────────
# AGENTS.md is auto-generated by GitNexus and mirrors the gitnexus
# section already in CLAUDE.md — a generated artefact, not source.
AGENTS.md

# ─── Agent skill installs (modern-web-guidance et al.) ────────
# `.agents/skills/` is the universal source dir written by
# installers like modern-web-guidance@latest install -- the per-
# agent symlinks (e.g. .claude/skills/) point at this directory.
# `skills-lock.json` is the installer's per-machine lockfile.
# All three are local install artefacts; contributors run the
# installer themselves.
.agents/
skills-lock.json

# ─── Test coverage (if added later) ────────────────────────────
/coverage/
/.nyc_output/

# ─── Editor & IDE ──────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── OS files ──────────────────────────────────────────────────
# macOS
.DS_Store
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
