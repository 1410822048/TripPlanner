VITE_USE_FIREBASE_EMULATORS=true
VITE_FIREBASE_EMULATOR_HOST=127.0.0.1
VITE_FIREBASE_PROJECT_ID=demo-tripmate
VITE_FIREBASE_API_KEY=demo
VITE_FIREBASE_AUTH_DOMAIN=demo-tripmate.firebaseapp.com
VITE_FIREBASE_STORAGE_BUCKET=demo-tripmate.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:emulator
VITE_DEV_EMULATOR_PASSWORD=tripmate-dev-password

# 路線預覽：Mapbox public token 會編譯進前端，只能使用 pk_ token，並在
# Mapbox Dashboard 限制 localhost／正式 Pages 網域。不要填入任何 provider secret。
VITE_MAPBOX_TOKEN=

# Worker 路線 API：本機以 `cd workers/ocr; npm run dev` 啟動後的 URL。
# 正式建置由 deploy script 注入正式 Worker URL，不要將 provider API key 放在這裡。
VITE_WORKER_BASE_URL=http://127.0.0.1:8787
