rules_version = '2';

// TripMate v1 access model:
//   - Trip docs are gated by a `members/{uid}` subdoc (doc-id == auth uid).
//   - Membership check is O(1) via exists(); avoids query-in-rules.
//   - Roles: owner (full control, only one per trip), editor (CRUD subcollections),
//     viewer (read-only). Owner must match trips/{tripId}.ownerId.
//   - Cross-trip listing: a collection-group query on /members/ finds every trip
//     the signed-in user belongs to; the top-level wildcard rule gates this to
//     "only your own member docs".
//   - Invites: unguessable 256-bit token as docId. Owner creates, redeemer reads
//     (via known path) + consumes atomically with member self-create.
//   - Default deny at the bottom catches anything outside these matches.

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Identity / membership predicates ─────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function uid() {
      return request.auth.uid;
    }
    // Self-access gate. Used wherever "I can read/write my own row" is
    // legitimate independent of trip membership — most importantly the
    // invite redeem flow, where the new user needs to getDoc(members/me)
    // before they have actually joined.
    function isSelf(id) {
      return isSignedIn() && id == uid();
    }
    // Same-doc membership predicate. The denormalised `memberIds: string[]`
    // is cascaded onto every trip-scoped doc (trip + members + 5 entity
    // subcollections) via memberSync, so reads check membership against
    // the doc being read — NO cross-document exists() / get() that
    // suffers Firestore's rules-eval propagation lag window (which used
    // to 403 listeners attaching right after a fresh batch.commit).
    function memberOfDoc() {
      return isSignedIn() && uid() in resource.data.memberIds;
    }
    function memberPath(tripId) {
      return /databases/$(database)/documents/trips/$(tripId)/members/$(uid());
    }
    // Cross-doc canWrite kept for WRITE rules — writes are rare and
    // user-initiated (they tolerate the rare 1-shot 403 from rules-lag
    // far better than silent listener deaths). Switching writes to
    // same-doc would need a `writerUids` denormalisation too; deferred
    // until usage proves it worth the cascade cost.
    function canWrite(tripId) {
      return isSignedIn()
        && get(memberPath(tripId)).data.role in ['owner', 'editor'];
    }
    function isTripOwner(tripId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/trips/$(tripId))
        && get(/databases/$(database)/documents/trips/$(tripId)).data.ownerId == uid();
    }
    function invitePath(tripId, token) {
      return /databases/$(database)/documents/trips/$(tripId)/invites/$(token);
    }

    // ─── Field-level update guards ────────────────────────────────
    // Each entity's update rule should explicitly preserve identity /
    // ownership / creation-audit fields so a malicious (or buggy) client
    // can't tamper with them via a doctored updateDoc payload. Without
    // these guards, any field not specifically required by the rule is
    // free to mutate — a member could re-assign `proposedBy` to themselves,
    // overwrite `createdAt` to game sort order, or change `tripId` to
    // orphan the doc into a different trip's path.
    //
    // `unchanged(field)` returns true iff the field has the same value
    // on the incoming write as on the existing doc.
    // `changedOnly(allowed)` returns true iff every field touched by the
    // update is in `allowed` — used for narrow self-service paths where
    // a member can only modify a specific subset (vote toggles, member
    // self-add to bookings.memberIds).
    // diff()-based so it works even when `field` is missing on either
    // side (returns true when neither doc has the field). The naive
    // `request.resource.data[field] == resource.data[field]` throws
    // "Property is undefined on object" if the field never existed --
    // problematic for optional fields like trip.deletionStartedAt.
    function unchanged(field) {
      return !(field in request.resource.data.diff(resource.data).affectedKeys());
    }
    function affectedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }
    function changedOnly(allowed) {
      return affectedKeys().hasOnly(allowed);
    }

    // ─── Soft-delete helpers (settlement phase-2) ────────────────
    // `d` is either resource.data (current) or request.resource.data
    // (target). "alive" means deletedAt is missing OR explicitly null;
    // "tombstoned" means deletedAt is present and a real Timestamp.
    function expenseAlive(d) {
      return !('deletedAt' in d) || d.deletedAt == null;
    }
    function expenseTombstoned(d) {
      return 'deletedAt' in d && d.deletedAt is timestamp;
    }

    // KNOWN BROKEN -- NOT A SECURITY BOUNDARY. Accepted risk pending
    // migration of tripCascade to a Worker / Admin SDK endpoint.
    //
    // What this gate ACTUALLY achieves: it disarms "owner accidentally
    // forgets to clean up" failure modes (5-minute self-expire) and
    // prevents flag forgery via the `request.time` constraint on the
    // trip update path.
    //
    // What it does NOT achieve: blocking a malicious / curious owner
    // from using raw SDK to (a) open the window themselves via
    // `updateDoc(trip, deletionStartedAt: serverTimestamp())`, then
    // (b) `deleteDoc(expense)` for any chosen expense within those 5
    // minutes -- erasing that expense's tombstone and demoting any
    // associated settlement reason to UNKNOWN. Client-side rules
    // CANNOT distinguish "legitimate cascade in progress" from "owner
    // opening a window to selectively delete"; both write shapes are
    // identical from a rules perspective.
    //
    // This is accepted risk for now because:
    //   1. The trip owner already has the nuclear option (cascade the
    //      entire trip, taking all tombstones with it). Selective-
    //      delete is strictly weaker than nuclear delete and operates
    //      within the owner's existing authority.
    //   2. TripMate's data-integrity story between trip members already
    //      relies on owner-honesty (an owner could lie about expenses
    //      or recreate trips outside the system).
    //   3. The proper fix -- moving tripCascade to a Worker endpoint
    //      that uses Admin SDK + reverting `allow delete: if false`
    //      for clients -- is deferred to the same CF/Worker
    //      infrastructure batch as the 10-day receipt purge (see
    //      project_settlement_phase2_temporal memory).
    function tripDeletionActive(tripId) {
      let tripDoc = get(/databases/$(database)/documents/trips/$(tripId));
      return tripDoc.data.deletionStartedAt is timestamp
          && tripDoc.data.deletionStartedAt <= request.time
          && request.time - tripDoc.data.deletionStartedAt < duration.value(5, 'm');
    }

    // ─── memberIds anti-injection guard ──────────────────────────
    // Defends against an editor injecting a stranger's uid into a new
    // entity's `memberIds`. Without this, the collection-group list
    // rule on /bookings (`uid in resource.data.memberIds`) would let
    // that stranger see this trip's hotel via PastLodgingPage's
    // cross-trip query. Same risk exists for any rule that grants
    // read based on `uid in memberIds` (memberOfDoc).
    //
    // Strategy: pin memberIds on new entity docs to be exactly equal
    // to the parent trip's current memberIds. The service layer
    // (`getTripMemberIds(tripId)`) reads from `trip.memberIds`, so
    // honest clients always satisfy this — only forged payloads fail.
    //
    // memberSync cascade paths (memberSyncSelfAdd / ownerSyncRemove)
    // operate via `update`, not `create`, so this gate doesn't conflict
    // with the invite-accept / remove-member flows.
    function memberIdsMatchTrip(tripId) {
      return request.resource.data.memberIds ==
        get(/databases/$(database)/documents/trips/$(tripId)).data.memberIds;
    }

    // ─── Attachment shape guards ─────────────────────────────────
    // Without these, an editor with a raw-SDK client could write
    // `attachment.fileUrl: 'https://evil.com/track.png'` and every
    // trip member's UI would fetch that URL on render (privacy /
    // tracking leak). Same risk for filePath pointing outside the
    // booking's own Storage folder (subsequent delete fails to purge
    // the orphaned object, or worse, traverses to delete a sibling).
    //
    // The honest service-layer path (`bookingService.createBooking`
    // / `updateBooking` → `uploadAttachment`) always produces values
    // matching these constraints, so legitimate writes are unaffected.
    // BUCKET HARDCODE — production-only contract. If a staging / mirror
    // bucket is ever introduced, every attachment write will be denied
    // until this constant is updated (rules don't support env-var
    // injection). A staging deploy would need a separate rules variant.
    //
    // Binds a Firebase Storage download URL to its exact `expectedPath`.
    // Without binding, an editor with raw-SDK access could write
    // `fileUrl` pointing at a different Storage object than `filePath`
    // claims — either cross-trip (PII leak) or same-folder different-
    // filename (delete-purge sees `filePath`'s name, leaves the URL'd
    // file orphan in Storage forever).
    //
    // We avoid regex matching here: a regex like `file.webp` would
    // accept `fileXwebp` too (RE2's literal-`.` semantics), and rules
    // don't have a string-escape function. Instead we split off the
    // query string and string-compare the rest — exact match required.
    function validStorageUrlFor(url, expectedPath) {
      return url is string
        && url.size() <= 2048
        && url.split('\\?')[0] ==
             'https://firebasestorage.googleapis.com/v0/b/tripplanner-80a4f.firebasestorage.app/o/'
             + expectedPath.replace('/', '%2F');
    }
    function validWishImage(tripId, wishId) {
      return !('image' in request.resource.data) || (
        request.resource.data.image is map
        && request.resource.data.image.keys().hasOnly(
             ['url', 'path', 'thumbUrl', 'thumbPath']
           )
        && request.resource.data.image.keys().hasAll(
             ['url', 'path', 'thumbUrl', 'thumbPath']
           )
        && request.resource.data.image.path is string
        && request.resource.data.image.path.size() <= 500
        && request.resource.data.image.path.matches(
             '^trips/' + tripId + '/wishes/' + wishId + '/.+'
           )
        && request.resource.data.image.thumbPath is string
        && request.resource.data.image.thumbPath.size() <= 500
        && request.resource.data.image.thumbPath.matches(
             '^trips/' + tripId + '/wishes/' + wishId + '/.+'
           )
        // URL bound to its own path — blocks both the same-bucket
        // cross-trip forge (`url=https://.../o/trips%2FOTHER%2F...`)
        // AND the same-folder filename swap that would orphan files
        // in Storage on delete.
        && validStorageUrlFor(
             request.resource.data.image.url,
             request.resource.data.image.path
           )
        && validStorageUrlFor(
             request.resource.data.image.thumbUrl,
             request.resource.data.image.thumbPath
           )
      );
    }
    function validExpenseReceipt(tripId, expenseId) {
      return !('receipt' in request.resource.data) || (
        request.resource.data.receipt is map
        && request.resource.data.receipt.keys().hasOnly(
             ['url', 'path', 'type', 'thumbUrl', 'thumbPath']
           )
        && request.resource.data.receipt.keys().hasAll(
             ['url', 'path', 'type']
           )
        // thumbUrl and thumbPath are paired — both present or both absent.
        // Without this, raw SDK could set thumbUrl alone, UI displays the
        // (unbacked) thumbUrl, but delete sees no thumbPath to purge.
        && ('thumbUrl' in request.resource.data.receipt) ==
             ('thumbPath' in request.resource.data.receipt)
        && request.resource.data.receipt.type in
             ['image/webp', 'image/jpeg', 'image/png', 'image/heic', 'image/heif', 'application/pdf']
        && request.resource.data.receipt.path is string
        && request.resource.data.receipt.path.size() <= 500
        && request.resource.data.receipt.path.matches(
             '^trips/' + tripId + '/expenses/' + expenseId + '/.+'
           )
        && validStorageUrlFor(
             request.resource.data.receipt.url,
             request.resource.data.receipt.path
           )
        && (!('thumbUrl' in request.resource.data.receipt) || (
              request.resource.data.receipt.thumbPath is string
              && request.resource.data.receipt.thumbPath.size() <= 500
              && request.resource.data.receipt.thumbPath.matches(
                   '^trips/' + tripId + '/expenses/' + expenseId + '/.+'
                 )
              && validStorageUrlFor(
                   request.resource.data.receipt.thumbUrl,
                   request.resource.data.receipt.thumbPath
                 )
           ))
      );
    }
    function validBookingAttachment(tripId, bookingId) {
      return !('attachment' in request.resource.data) || (
        request.resource.data.attachment is map
        && request.resource.data.attachment.keys().hasOnly(
             ['fileUrl', 'filePath', 'fileType', 'thumbUrl', 'thumbPath']
           )
        && request.resource.data.attachment.keys().hasAll(
             ['fileUrl', 'filePath', 'fileType']
           )
        // thumbUrl and thumbPath are paired — see validExpenseReceipt above.
        && ('thumbUrl' in request.resource.data.attachment) ==
             ('thumbPath' in request.resource.data.attachment)
        && request.resource.data.attachment.fileType in
             ['image/webp', 'image/jpeg', 'image/png', 'image/heic', 'image/heif', 'application/pdf']
        && request.resource.data.attachment.filePath is string
        && request.resource.data.attachment.filePath.size() <= 500
        && request.resource.data.attachment.filePath.matches(
             '^trips/' + tripId + '/bookings/' + bookingId + '/.+'
           )
        && validStorageUrlFor(
             request.resource.data.attachment.fileUrl,
             request.resource.data.attachment.filePath
           )
        && (!('thumbUrl' in request.resource.data.attachment) || (
              request.resource.data.attachment.thumbPath is string
              && request.resource.data.attachment.thumbPath.size() <= 500
              && request.resource.data.attachment.thumbPath.matches(
                   '^trips/' + tripId + '/bookings/' + bookingId + '/.+'
                 )
              && validStorageUrlFor(
                   request.resource.data.attachment.thumbUrl,
                   request.resource.data.attachment.thumbPath
                 )
           ))
      );
    }

    // ─── Membership-sync update predicates ────────────────────────
    // These authorise the memberSync cascade — when a user accepts an
    // invite OR the owner removes a member, memberIds[] is bumped on
    // every trip-scoped doc (trip, members, all 5 entity subcollections).
    // The write rules below allow these specific diffs WITHOUT requiring
    // canWrite (which would lock invitees out) or content-edit gates
    // (which would lock owner cascade out).
    //
    // memberSyncSelfAdd: caller appends THEIR OWN uid, exactly once,
    // to memberIds. Requires they hold a member doc at this trip so
    // a stranger can't self-add via this path. The pre-existing
    // entity/member docs that the invitee couldn't list themselves
    // are cascaded by the OCR worker's /cascade-member endpoint
    // (service-account, bypasses rules) — see workers/ocr/src/cascade.ts.
    function memberSyncSelfAdd(tripId) {
      return isSignedIn()
        && exists(memberPath(tripId))
        && changedOnly(['memberIds'])
        && uid() in request.resource.data.memberIds
        && !(uid() in resource.data.memberIds)
        && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1;
    }
    // ownerSyncRemove: only the trip owner can strip a uid from memberIds.
    // memberIds is the only field allowed to change — content edits
    // route through the canWrite branch above.
    function ownerSyncRemove(tripId) {
      return isTripOwner(tripId)
        && changedOnly(['memberIds'])
        && request.resource.data.memberIds.size() == resource.data.memberIds.size() - 1;
    }

    // Collection-group list gate for /members. Used by getMyTrips() to find
    // every trip the user belongs to (owner OR editor OR viewer). The rule
    // restricts results to the caller's own member docs; clients must query
    // `where('userId','==',uid)` or Firestore rejects the query.
    //
    // Placed outside /trips/{tripId}/members because collection-group rules
    // must use a wildcard parent path. The specific rules below still govern
    // get/create/update/delete on individual member docs.
    match /{path=**}/members/{memberId} {
      allow list: if isSignedIn() && resource.data.userId == uid();
    }

    // Collection-group list gate for /bookings. Used by getMyHotelBookings()
    // (PastLodgingPage) to fetch every hotel booking across every trip the
    // user belongs to in one query, replacing the old N-trip fan-out.
    //
    // The rule mirrors the members pattern: clients MUST filter by
    // `where('memberIds', 'array-contains', uid)` or Firestore rejects.
    // The denormalised memberIds array is synced by inviteService (on
    // accept) and memberService (on remove). Per-trip get/create/update/
    // delete still go through the path-scoped rule below.
    match /{path=**}/bookings/{bookingId} {
      allow list: if isSignedIn() && uid() in resource.data.memberIds;
    }

    match /trips/{tripId} {
      // GET by id (including shared trips I'm invited to) → same-doc
      // memberIds check. No cross-document exists(), no rules-lag.
      // `resource == null` clause lets listeners on orphan/just-deleted
      // trip docs receive `snap.exists() === false` cleanly instead of
      // a permission-denied target error — common after cascade-delete
      // races and Console-deleted trips that left orphan member docs
      // in the collection-group (Firestore doesn't auto-cascade
      // subcollection deletes from a parent doc delete in the Console).
      allow get: if resource == null || memberOfDoc();
      // LIST/query on /trips is kept narrow: only "trips I own" via ownerId
      // filter. The primary list path is now the /members collection-group
      // query above, so this rule is effectively a defensive fallback.
      allow list: if isSignedIn() && resource.data.ownerId == uid();
      // Anyone signed-in may create a trip they own; ownerId is pinned
      // to their uid. memberIds must start as exactly [uid] so the
      // initial roster matches the owner-only state — memberSync
      // extends it as invitees redeem.
      allow create: if isSignedIn()
                    && request.resource.data.ownerId == uid()
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0
                    && request.resource.data.title.size() <= 100
                    && request.resource.data.destination is string
                    && request.resource.data.destination.size() <= 200
                    && request.resource.data.memberIds == [uid()];
      // Five update paths:
      //   1. Owner edits trip metadata (title/dates/icon/currency).
      //      ownerId + createdAt pinned to prevent transfer / forgery.
      //      memberIds locked too — only memberSync paths can touch it.
      //   2. Invitee self-add via memberSync cascade after acceptInvite
      //      writes the new member doc.
      //   3. Owner remove-member cascade strips uid from memberIds.
      //   4. Any member bumps lastActivityByFeature — drives the
      //      bottom-nav unread-dot badge. Called after every entity
      //      mutation (best-effort fire-and-forget). `by` field NOT
      //      validated server-side: forging it only causes the forger's
      //      own badge to fire incorrectly — no security impact, so
      //      the rule stays lenient.
      //   5. Owner sets / clears `deletionStartedAt` (cascade-delete
      //      window marker). MUST equal request.time on set so the
      //      5-minute window check in `tripDeletionActive()` operates
      //      on a server-stamped value, not a client-forged Timestamp.
      //      Clearing to null is allowed (cancel cascade).
      allow update: if (
        isTripOwner(tripId)
        && unchanged('ownerId')
        && unchanged('createdAt')
        && unchanged('memberIds')
        && unchanged('deletionStartedAt')
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 100
        && request.resource.data.destination is string
        && request.resource.data.destination.size() <= 200
      ) || memberSyncSelfAdd(tripId) || ownerSyncRemove(tripId) || (
        memberOfDoc()
        && changedOnly(['lastActivityByFeature', 'updatedAt'])
        && request.resource.data.lastActivityByFeature is map
        && request.resource.data.lastActivityByFeature.keys().hasOnly(
             ['schedule', 'bookings', 'expense', 'wish', 'planning']
           )
      ) || (
        isTripOwner(tripId)
        && changedOnly(['deletionStartedAt', 'updatedAt'])
        && (
          request.resource.data.deletionStartedAt == null
          || request.resource.data.deletionStartedAt == request.time
        )
      );
      allow delete: if isTripOwner(tripId);

      match /members/{memberId} {
        // get: anyone can fetch their OWN member doc, even when they're
        //      not yet a member. The invite-redeem flow needs this for
        //      the "already-member?" idempotency check (acceptInvite
        //      reads its own member doc before deciding whether to
        //      setDoc). Without the isSelf clause, redeemers got
        //      "Missing or insufficient permissions" on the read.
        // list: still member-only — viewing the full roster is a
        //       trip-internal action. Each member doc carries the full
        //       roster via memberIds[] so the check is same-doc.
        allow get:  if memberOfDoc() || isSelf(memberId);
        allow list: if memberOfDoc();
        // Three creation paths:
        //   1. Owner self-bootstrap at trip creation (doc-id must be own uid,
        //      role pinned to 'owner', memberIds == [uid] to match the
        //      trip's initial roster).
        //   2. Owner manually adds a member (Phase 3 feature).
        //   3. Invitee self-redeems: doc-id is own uid, role matches the
        //      invite doc they reference via `inviteToken`. The rule
        //      dereferences the invite to verify role + non-expired. The
        //      invite doc is reusable — its existence is the validity gate;
        //      multiple redeemers may succeed in parallel. memberIds on
        //      the new doc must include the joiner so the same-doc read
        //      rule passes.
        allow create: if isSignedIn()
                      && uid() in request.resource.data.memberIds && (
          (memberId == uid()
            && request.resource.data.userId == uid()
            && request.resource.data.role == 'owner'
            && request.resource.data.memberIds == [uid()])
          || (
              // Owner manually adds a member (Phase 3 feature, not yet
              // wired in client). Lock userId / role so the owner can't
              // bypass the role allowlist or write mismatched identity.
              isTripOwner(tripId)
              && request.resource.data.userId == memberId
              && request.resource.data.role in ['editor', 'viewer']
            )
          || (memberId == uid()
              && request.resource.data.userId == uid()
              && request.resource.data.role in ['editor', 'viewer']
              && exists(invitePath(tripId, request.resource.data.inviteToken))
              && get(invitePath(tripId, request.resource.data.inviteToken)).data.role == request.resource.data.role
              && get(invitePath(tripId, request.resource.data.inviteToken)).data.expiresAt > request.time)
        );
        // Three update paths:
        //   1. Owner edits roles. Identity fields locked, memberIds locked.
        //   2. Invitee self-add cascade after acceptInvite (memberSync
        //      touches every existing member doc's memberIds).
        //   3. Owner remove-member cascade.
        allow update: if (
          isTripOwner(tripId)
          && unchanged('userId')
          && unchanged('tripId')
          && unchanged('joinedAt')
          && unchanged('memberIds')
        ) || memberSyncSelfAdd(tripId) || ownerSyncRemove(tripId);
        allow delete: if isTripOwner(tripId);
      }

      match /invites/{token} {
        // Redeemer reads by known path (the 256-bit token is the auth). Owner
        // lists their invites for the management UI.
        allow get:  if isSignedIn();
        allow list: if isTripOwner(tripId);
        // Owner creates invites. Required fields shape + role allowlist; the
        // invite must not be backdated past expiry.
        allow create: if isTripOwner(tripId)
                      && request.resource.data.tripId == tripId
                      && request.resource.data.createdBy == uid()
                      && request.resource.data.role in ['editor', 'viewer']
                      && request.resource.data.tripTitle is string
                      && request.resource.data.tripIcon is string
                      && request.resource.data.expiresAt is timestamp
                      && request.resource.data.expiresAt > request.time;
        // No update path: invites are immutable once created. Owner rotates
        // by delete+create (handled by createInvite's writeBatch). Default
        // deny from the absence of `allow update` is the intended posture.
        //
        // Owner revokes by deleting. Also used implicitly by createInvite to
        // clear older invites before writing the new one — reusable-link
        // semantics: existing doc = valid, missing doc = invalid.
        allow delete: if isTripOwner(tripId);
      }

      match /schedules/{scheduleId} {
        allow read:   if memberOfDoc();
        // updatedBy on create must equal caller — same uid-forge defence as
        // updates; powers the tab unread-dot filter (own writes don't badge).
        // memberIdsMatchTrip blocks editor-side injection of stranger uids.
        // Type / size / enum checks mirror the client Zod schema as
        // defense-in-depth against REST-API misuse.
        allow create: if canWrite(tripId)
                      && request.resource.data.tripId == tripId
                      && request.resource.data.createdBy == uid()
                      && request.resource.data.updatedBy == uid()
                      && memberIdsMatchTrip(tripId)
                      && request.resource.data.title is string
                      && request.resource.data.title.size() > 0
                      && request.resource.data.title.size() <= 200
                      && request.resource.data.category in
                           ['transport','accommodation','food','activity','shopping','other'];
        allow update: if (
          canWrite(tripId)
          && unchanged('tripId')
          && unchanged('createdBy')
          && unchanged('createdAt')
          && unchanged('memberIds')
          && request.resource.data.updatedBy == uid()
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.title.size() <= 200
          && request.resource.data.category in
               ['transport','accommodation','food','activity','shopping','other']
        ) || memberSyncSelfAdd(tripId) || ownerSyncRemove(tripId);
        allow delete: if canWrite(tripId);
      }

      match /expenses/{expenseId} {
        allow read:   if memberOfDoc();
        allow create: if canWrite(tripId)
                      && request.resource.data.tripId == tripId
                      && request.resource.data.createdBy == uid()
                      && request.resource.data.updatedBy == uid()
                      && memberIdsMatchTrip(tripId)
                      && request.resource.data.title is string
                      && request.resource.data.title.size() > 0
                      && request.resource.data.title.size() <= 200
                      && request.resource.data.amount is number
                      && request.resource.data.amount > 0
                      && request.resource.data.splits is list
                      && request.resource.data.splits.size() <= 50
                      && request.resource.data.category in
                           ['food','transport','accommodation','activity','shopping','other']
                      // deletedAt MUST be present AND null on create.
                      // Forcing the field at create-time makes future
                      // `where('deletedAt', '==', null)` server-side
                      // filtering work without missing-field exclusions.
                      && 'deletedAt' in request.resource.data
                      && request.resource.data.deletedAt == null
                      && validExpenseReceipt(tripId, expenseId);
        allow update: if (
          canWrite(tripId)
          && unchanged('tripId')
          && unchanged('createdBy')
          && unchanged('createdAt')
          && unchanged('memberIds')
          && request.resource.data.updatedBy == uid()
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.title.size() <= 200
          && request.resource.data.amount is number
          && request.resource.data.amount > 0
          && request.resource.data.splits is list
          && request.resource.data.splits.size() <= 50
          && request.resource.data.category in
               ['food','transport','accommodation','activity','shopping','other']
          // Soft-delete invariants (settlement phase-2). See
          // expenseAlive / expenseTombstoned helpers at rules root.
          //
          // 1. Field never disappears once present (blocks deleteField()
          //    which would make the doc invisible to a future
          //    `where deletedAt == null` server-side query).
          && !(
            'deletedAt' in resource.data
            && !('deletedAt' in request.resource.data)
          )
          // 2. deletedAt transitions:
          //    - alive → alive: deletedAt stays null/absent
          //    - alive → tombstoned: target must equal request.time
          //      (no backdate / forward-date tampering)
          //    - tombstoned → null: restore. CURRENTLY unbounded at
          //      the rules layer; planned 10-day window + receipt
          //      retention lands when Cloud Function purge ships
          //      (see project_settlement_phase2_temporal memory)
          //    - tombstoned → same Timestamp: no-op tombstone update
          && (
            expenseAlive(request.resource.data)
            || (expenseAlive(resource.data) && request.resource.data.deletedAt == request.time)
            || (expenseTombstoned(resource.data)
                && request.resource.data.deletedAt == resource.data.deletedAt)
          )
          // 3. Tombstone freeze: when EITHER end-state is tombstoned,
          //    only audit + deletedAt may change. Blocks splits/amount
          //    mutation on tombstoned docs AND prevents bundling such
          //    mutation into the same write that soft-deletes (both
          //    attack vectors against settlement replay integrity).
          && (
            (expenseAlive(resource.data) && expenseAlive(request.resource.data))
            || changedOnly(['deletedAt', 'updatedBy', 'updatedAt'])
          )
          && validExpenseReceipt(tripId, expenseId)
        ) || memberSyncSelfAdd(tripId) || ownerSyncRemove(tripId);
        // Hard delete: owner-only AND only inside the trip's active
        // cascade-delete window. ACCEPTED RISK: owner can open the
        // window via raw SDK and selectively delete a single expense
        // (see `tripDeletionActive` doc -- KNOWN BROKEN, not a security
        // boundary). This rule is the WORKFLOW GATE for `tripCascade`,
        // not enforcement against a malicious owner. Proper closure
        // moves cascade to a Worker / Admin SDK endpoint and reverts
        // this clause back to `allow delete: if false`.
        //
        // Future hard-purge of aged tombstones runs through Admin SDK
        // (scheduled CF) which bypasses rules entirely.
        allow delete: if isTripOwner(tripId) && tripDeletionActive(tripId);
      }

      match /wishes/{wishId} {
        allow read:   if memberOfDoc();
        // Create open to ANY member (including viewer) — wishes are a
        // collaborative wishlist, everyone on the trip should be able
        // to suggest places / food / activities. Membership gate uses
        // a same-doc check via memberIds (no cross-doc) — the caller
        // must include themselves in the new doc's memberIds, AND
        // that array must be a non-empty subset of the trip's roster.
        // We trust the caller to copy the roster honestly because they
        // can't grant themselves membership: if uid wasn't already in
        // trip.memberIds, no other doc would have them, and they'd be
        // blocked everywhere else.
        allow create: if exists(memberPath(tripId))
                      && request.resource.data.tripId == tripId
                      && request.resource.data.proposedBy == uid()
                      && request.resource.data.updatedBy == uid()
                      && request.resource.data.votes == [uid()]
                      && memberIdsMatchTrip(tripId)
                      && request.resource.data.title is string
                      && request.resource.data.title.size() > 0
                      && request.resource.data.title.size() <= 200
                      && request.resource.data.category in ['place', 'food']
                      && (!('description' in request.resource.data)
                            || request.resource.data.description.size() <= 1000)
                      && (!('address' in request.resource.data)
                            || request.resource.data.address.size() <= 400)
                      && (!('link' in request.resource.data)
                            || request.resource.data.link.size() <= 1000)
                      && validWishImage(tripId, wishId);
        // Two update paths:
        //   1. Proposer edits any field (title/category/etc.)
        //   2. Any member toggles their own uid in the votes array. The
        //      diff predicate locks "votes-only change" + size delta of
        //      exactly ±1 + the changed entry is the caller's uid. This
        //      prevents a malicious member from clearing or hijacking
        //      others' votes.
        allow update: if (
          memberOfDoc() && (
            // 1. Proposer path: edit any field EXCEPT ownership / identity.
            (
              resource.data.proposedBy == uid()
              && unchanged('tripId')
              && unchanged('proposedBy')
              && unchanged('createdAt')
              && unchanged('memberIds')
              && request.resource.data.updatedBy == uid()
              && request.resource.data.title is string
              && request.resource.data.title.size() > 0
              && request.resource.data.title.size() <= 200
              && request.resource.data.category in ['place', 'food']
              && (!('description' in request.resource.data)
                    || request.resource.data.description.size() <= 1000)
              && (!('address' in request.resource.data)
                    || request.resource.data.address.size() <= 400)
              && (!('link' in request.resource.data)
                    || request.resource.data.link.size() <= 1000)
              && validWishImage(tripId, wishId)
            )
            ||
            // 2. Voter path: any member toggles only their own uid in `votes`.
            (
              changedOnly(['votes', 'updatedAt', 'updatedBy'])
              && request.resource.data.updatedBy == uid()
              && (
                (request.resource.data.votes.size() == resource.data.votes.size() + 1
                  && uid() in request.resource.data.votes
                  && !(uid() in resource.data.votes))
                ||
                (request.resource.data.votes.size() == resource.data.votes.size() - 1
                  && !(uid() in request.resource.data.votes)
                  && uid() in resource.data.votes)
              )
            )
          )
        ) || memberSyncSelfAdd(tripId) || ownerSyncRemove(tripId);
        // Two deletion paths:
        //   1. Proposer cleans up their own wish.
        //   2. Trip owner moderates — can remove any wish (e.g. spam,
        //      duplicates, wrong-trip mistakes). Owner already has the
        //      power to delete the entire trip; per-wish moderation is
        //      a strict subset of that authority.
        allow delete: if memberOfDoc()
                      && (resource.data.proposedBy == uid() || isTripOwner(tripId));
      }

      match /bookings/{bookingId} {
        allow read:   if memberOfDoc();
        allow create: if canWrite(tripId)
                      && request.resource.data.tripId == tripId
                      && request.resource.data.createdBy == uid()
                      && request.resource.data.updatedBy == uid()
                      && memberIdsMatchTrip(tripId)
                      && request.resource.data.type in ['flight','hotel','train','bus','other']
                      && (!('title' in request.resource.data)
                            || request.resource.data.title.size() <= 200)
                      && (!('origin' in request.resource.data)
                            || request.resource.data.origin.size() <= 100)
                      && (!('destination' in request.resource.data)
                            || request.resource.data.destination.size() <= 100)
                      && (!('confirmationCode' in request.resource.data)
                            || request.resource.data.confirmationCode.size() <= 100)
                      && (!('provider' in request.resource.data)
                            || request.resource.data.provider.size() <= 100)
                      && (!('address' in request.resource.data)
                            || request.resource.data.address.size() <= 400)
                      && validBookingAttachment(tripId, bookingId);
        // Three update paths:
        //   1. Editor / owner edits booking content. tripId / createdBy /
        //      createdAt locked. memberIds locked too — content edits
        //      must NOT silently rewrite the access roster (an editor
        //      could otherwise add a stranger's uid via a doctored
        //      payload + the stranger would then see this trip's hotels
        //      via the collection-group query).
        //   2. Invitee self-add cascade after acceptInvite.
        //   3. Owner remove-member cascade.
        allow update: if (
          canWrite(tripId)
          && unchanged('tripId')
          && unchanged('createdBy')
          && unchanged('createdAt')
          && unchanged('memberIds')
          && request.resource.data.updatedBy == uid()
          && request.resource.data.type in ['flight','hotel','train','bus','other']
          && (!('title' in request.resource.data)
                || request.resource.data.title.size() <= 200)
          && (!('origin' in request.resource.data)
                || request.resource.data.origin.size() <= 100)
          && (!('destination' in request.resource.data)
                || request.resource.data.destination.size() <= 100)
          && (!('confirmationCode' in request.resource.data)
                || request.resource.data.confirmationCode.size() <= 100)
          && (!('provider' in request.resource.data)
                || request.resource.data.provider.size() <= 100)
          && (!('address' in request.resource.data)
                || request.resource.data.address.size() <= 400)
          && validBookingAttachment(tripId, bookingId)
        ) || memberSyncSelfAdd(tripId) || ownerSyncRemove(tripId);
        allow delete: if canWrite(tripId);
      }

      // Settlement records — bilateral "X paid Y back" entries.
      // Only the receiver (toUid) can record it: receiver-confirms-receipt
      // prevents the payer from unilaterally marking themselves "paid back"
      // without the payee actually having received the money. settledBy
      // must equal toUid (i.e. uid()). amount is positive integer in the
      // trip currency. Immutable once recorded; revert via delete + re-create.
      match /settlements/{settlementId} {
        // Settlements don't carry memberIds[] (they're a bounded set
        // per trip and writes are rare — denormalising would pay cost
        // for no measurable benefit). Reads use the same-doc check on
        // the parent trip via exists() — a cross-doc lookup, but
        // settlements are only accessed inside ExpensePage which mounts
        // long after trip create, so the rules-eval lag window has
        // resolved by then.
        allow read:   if exists(memberPath(tripId));
        allow create: if exists(memberPath(tripId))
                      && request.resource.data.tripId == tripId
                      && request.resource.data.settledBy == uid()
                      && request.resource.data.toUid == uid()
                      && request.resource.data.amount is int
                      && request.resource.data.amount > 0
                      && request.resource.data.currency is string
                      // fromUid must be a real, distinct trip member —
                      // otherwise a receiver could fabricate
                      // "Charlie 還我 ¥100" records that pollute the
                      // settlement audit log without Charlie's input.
                      && request.resource.data.fromUid is string
                      && request.resource.data.fromUid != uid()
                      && exists(/databases/$(database)/documents/trips/$(tripId)/members/$(request.resource.data.fromUid));
        // Either the recorder undoing, or the trip owner moderating.
        allow delete: if exists(memberPath(tripId))
                      && (resource.data.settledBy == uid() || isTripOwner(tripId));
      }

      // Planning checklist — collaborative pre-trip prep. Any member
      // can add / edit / toggle / delete; the list is inherently shared
      // (one person packs the charger, another marks "currency
      // exchanged"). createdBy is pinned to the caller so audit trail
      // stays honest.
      match /planning/{itemId} {
        allow read:   if memberOfDoc();
        allow create: if exists(memberPath(tripId))
                      && request.resource.data.tripId == tripId
                      && request.resource.data.createdBy == uid()
                      && request.resource.data.updatedBy == uid()
                      && memberIdsMatchTrip(tripId)
                      && request.resource.data.title is string
                      && request.resource.data.title.size() > 0
                      && request.resource.data.title.size() <= 200
                      && request.resource.data.category in
                           ['essentials','documents','packing','todo','other']
                      && (!('note' in request.resource.data)
                            || request.resource.data.note.size() <= 1000);
        // Three update paths: content edit (any member), invitee
        // self-add cascade, owner remove-member cascade.
        allow update: if (
          memberOfDoc()
          && unchanged('tripId')
          && unchanged('createdBy')
          && unchanged('createdAt')
          && unchanged('memberIds')
          && request.resource.data.updatedBy == uid()
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.title.size() <= 200
          && request.resource.data.category in
               ['essentials','documents','packing','todo','other']
          && (!('note' in request.resource.data)
                || request.resource.data.note.size() <= 1000)
        ) || memberSyncSelfAdd(tripId) || ownerSyncRemove(tripId);
        allow delete: if memberOfDoc();
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
