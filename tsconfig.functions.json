{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.functions.tsbuildinfo",
    "target": "es2023",
    /* Cloudflare Pages Functions run on the Workers runtime — WebWorker lib
       (not DOM) so accidental window/document usage fails typecheck here
       instead of at runtime. */
    "lib": ["ES2023", "WebWorker", "WebWorker.Iterable"],
    "module": "esnext",
    "types": [],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Strictness — mirror tsconfig.app.json */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["functions"]
}
