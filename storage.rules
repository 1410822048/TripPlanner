rules_version = '2';

// TripMate Storage access model:
//   - Entity attachments live under /trips/{tripId}/{collection}/{entityId}/{filename}
//     where collection is one of: expenses, bookings, wishes.
//   - Read is open to any trip member; write requires editor/owner role
//     (expense/booking) or proposer (wish). Trip-deleting state blocks writes.
//   - Storage rules are a STABLE GATE, not a complete intent gate. They
//     enforce only self-consistent metadata + upload-time permission:
//     uid matches caller, claimed tripId/entityType/entityId match URL
//     params, size ≤ 5MB, content-type in per-entity allowlist,
//     uploadIntentId is a 32-char string, current role / membership /
//     tripNotDeleting still hold. They do NOT verify the intent doc
//     EXISTS, is unused, has not expired, or was minted for this exact
//     path -- those are enforced AUTHORITATIVELY by the Worker when it
//     consumes the intent in /booking-file-*, /wish-file-*,
//     /expense-create, /expense-update. The split is deliberate: see
//     "DO NOT add cross-service reads on freshly-written docs" below.
//   - Default deny at the bottom catches anything outside /trips/.
//
// DO NOT add cross-service reads on freshly-written docs.
//   Phase 3.5 (2026-05-24) shipped a version of `intentMatches()` that
//   ran `firestore.exists/get` on the just-minted uploadIntent doc to
//   verify status / expiresAt / path. The doc was readable via Firestore
//   REST within milliseconds of the write, but the cross-service path
//   from Storage rules has a short staleness window and returned `false`
//   for that doc -- denying every upload with 403 despite Worker +
//   client + metadata all being correct.
//
//   Fix: intent validity (status / expiresAt / path / contentType /
//   single-use) is enforced when the Worker consumes the intent at
//   the entity-write endpoints (/booking-file-*, /wish-file-*,
//   /expense-create, /expense-update). Storage rules verify only
//   self-contained metadata + a length check on uploadIntentId.
//
//   When adding any new cross-service read here, ask: "is this doc
//   fresh (client just got it from a Worker / just-wrote it itself)?"
//   If yes, redesign to use self-contained metadata + Worker
//   verification. If no (member docs, trip docs, wish docs -- all
//   minutes-to-hours old by upload time), the cross-service read is
//   fine.
//
// IAM note:
//   Cross-service reads run under the Cloud Storage for Firebase service
//   agent (`service-{projectNumber}@gcp-sa-firebasestorage.iam.gserviceaccount.com`)
//   with role `roles/firebaserules.firestoreServiceAgent` (single
//   permission: `datastore.entities.get`). Firebase auto-provisions
//   this on first Console save with a CEL Condition scoped to the path
//   prefixes the rule then referenced; `firebase deploy --only storage`
//   from CLI does NOT re-trigger that grant flow.
//
//   In practice: cross-service reads stay under `trips/*` (the original
//   scope), so the Condition keeps covering them. If a future feature
//   genuinely needs a cross-service read on a NEW top-level collection
//   (rather than a `trips/{tripId}/...` subcollection), manually widen
//   the IAM Condition in Cloud Console before relying on it. The 2026-
//   05-24 prod 403 was NOT this -- it was the race above -- but the
//   note still holds for legitimately-fresh top-level reads.
//   Ref: https://firebase.google.com/docs/storage/security/rules-conditions

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    // Role-aware membership: read is open to any member; create/update/
    // delete require editor or owner. Mirrors the canWrite() gate in
    // firestore.rules so the two services agree on who can mutate trip
    // data — previously Storage was looser (any member could write),
    // letting a viewer theoretically POST attachments via the raw API
    // even though the UI hides the button.
    function memberDoc(tripId) {
      return /databases/(default)/documents/trips/$(tripId)/members/$(request.auth.uid);
    }
    function tripDoc(tripId) {
      return /databases/(default)/documents/trips/$(tripId);
    }
    function isMember(tripId) {
      return isSignedIn() && firestore.exists(memberDoc(tripId));
    }
    function canWriteFiles(tripId) {
      return isSignedIn()
        && firestore.get(memberDoc(tripId)).data.role in ['owner', 'editor']
        && !('removingAt' in firestore.get(memberDoc(tripId)).data);
    }
    // Cross-service mirror of firestore.rules' tripNotDeleting helper.
    // The Worker's /cascade-trip-delete sets `trip.deletingAt` BEFORE
    // anything else; this gate ensures any in-flight Storage upload on
    // another device is rejected the same way Firestore creates are.
    // Without this, an upload that lands between the Worker's Storage
    // purge and trip-doc delete steps would survive the cascade and
    // become an orphan blob (Firestore create blocked → no
    // expense/booking/wish doc referencing it → no path back to it
    // from the UI, but bytes keep billing).
    function tripNotDeleting(tripId) {
      return !('deletingAt' in firestore.get(tripDoc(tripId)).data);
    }

    // Wish cover Storage ownership.
    //
    // proposer-gate is enforced AUTHORITATIVELY at the Worker, NOT here:
    //   - /upload-intents reads the wish doc with Admin SDK (strong
    //     consistency, no cross-service staleness) and refuses to mint
    //     for non-proposer.
    //   - /wish-file-create / /wish-file-update read the wish doc with
    //     Admin SDK again and refuse to write wish.image for non-
    //     proposer, then mark the intent used in the same transaction.
    //
    // Storage rules used to call isWishProposer in `allow create` as
    // defense-in-depth. The 2026-05-26 production incident (systematic
    // 403 on every "create wish + simultaneous cover image" flow)
    // proved that read was racing on the freshly-written wish doc:
    // the cross-service Storage→Firestore path has a sub-second
    // staleness window, same class as the 2026-05-24 intent-doc race.
    // wishService.createWish is doc-first by necessity (the wishId is
    // needed in the intent path), so the wish doc is ALWAYS milliseconds
    // old when Storage rules try to read it -- the race fires every
    // time, not occasionally.
    //
    // Fix: storage.rules stop gating CREATE on isWishProposer. The
    // Worker is already the authoritative proposer gate at both intent
    // mint and entity-write consume. Storage rules verify only stable claimed
    // metadata (intentMatches: uploaderUid match + tripId/entityType/
    // entityId/schemaVersion match + size/contentType allowlist +
    // 32-char intentId shape) plus isMember + tripNotDeleting at upload
    // time. A non-proposer cannot get an intent minted, and a stolen
    // intent locks uploaderUid -- so the Storage-side proposer check
    // was redundant relative to Worker enforcement.
    //
    // isWishProposer IS still used for `allow delete`. That read is
    // safe: by the time anyone deletes a wish cover, the wish doc has
    // been around for minutes-to-hours, well past any staleness window.
    function wishPath(tripId, wishId) {
      return /databases/(default)/documents/trips/$(tripId)/wishes/$(wishId);
    }
    function isWishProposer(tripId, wishId) {
      return firestore.exists(wishPath(tripId, wishId))
          && firestore.get(wishPath(tripId, wishId)).data.proposedBy == request.auth.uid;
    }
    // Cross-service trip-owner check. Mirrors firestore.rules
    // `isTripOwner` so the wish delete rule can match firestore.rules'
    // moderation disjunction (proposer OR trip owner). Without this
    // Storage stays proposer-only and the owner-moderation path on
    // Firestore orphans cover blobs (Firestore doc deletes, Storage
    // returns 403, frontend swallows the Storage error → bytes leak).
    function isTripOwnerStorage(tripId) {
      return isSignedIn()
          && firestore.get(tripDoc(tripId)).data.ownerId == request.auth.uid;
    }

    // Phase 3.5 upload metadata verification. Every entity upload must
    // carry an uploadIntentId + the Worker-owned metadata shape minted
    // by /upload-intents. Storage rules validate stable properties ONLY:
    //   - uploadIntentId is a 32-char string (shape, not validity)
    //   - request.resource.size ≤ 5MB
    //   - contentType matches the kind ('full'/'thumb' → image allowlist;
    //     'pdf' → application/pdf, and not on wish path)
    //   - metadata.uploaderUid == request.auth.uid
    //   - metadata.tripId / entityType / entityId match the URL params
    //   - schemaVersion == 'v1'
    // Plus the upload-time permission checks at each match block:
    // canWriteFiles / isWishProposer + tripNotDeleting.
    //
    // What Storage rules do NOT verify (Worker entity-write endpoints
    // own these on intent consume, where they read the intent doc by id):
    //   - the intent doc exists at all
    //   - intent.status == 'pending' (not already used)
    //   - intent.expiresAt > now (within 30-min window)
    //   - intent.path / contentType / size exactly match this upload
    //     (Storage only knows what the CLIENT claimed in metadata; the
    //     intent doc is the source of truth)
    //   - intent is consumed at most once
    //
    // Do NOT read the just-created uploadIntent doc here. In production,
    // the client immediately uploads after /upload-intents returns, and
    // Storage rules' cross-service firestore.exists/get can fail that
    // read-after-write window even though the doc is already visible via
    // Firestore REST -- the 2026-05-24 prod 403 incident. Authoritative
    // intent validity belongs at the Worker layer where the read is on
    // a doc that's been around long enough to propagate.
    //
    // Why intent metadata + immediate-permission BOTH: the intent was
    // minted up to 30 min ago. During that window the user could be
    // demoted, removed from the trip, or the trip could enter
    // deletingAt cascade. The rules layer's role / membership /
    // tripNotDeleting checks run at upload time, so a stale-permission
    // capability token can't slip through. Intent metadata narrows
    // what the upload CLAIMS to be; role check confirms the caller
    // still has the role to write here.
    function imageContentType() {
      return request.resource.contentType in [
        'image/webp',
        'image/jpeg',
        'image/png',
        'image/heic',
        'image/heif',
      ];
    }
    function uploadContentTypeOk(entityType) {
      return (
          request.resource.metadata.kind == 'pdf'
          && entityType != 'wish'
          && request.resource.contentType == 'application/pdf'
        ) || (
          request.resource.metadata.kind in ['full', 'thumb']
          && imageContentType()
        );
    }
    function intentMatches(tripId, entityType, entityId) {
      return isSignedIn()
        && 'uploadIntentId' in request.resource.metadata
        && request.resource.metadata.uploadIntentId is string
        && request.resource.metadata.uploadIntentId.size() == 32
        && request.resource.size <= 5 * 1024 * 1024
        && uploadContentTypeOk(entityType)
        && request.resource.metadata.uploaderUid == request.auth.uid
        && request.resource.metadata.tripId == tripId
        && request.resource.metadata.entityType == entityType
        && request.resource.metadata.entityId == entityId
        && request.resource.metadata.schemaVersion == 'v1';
    }

    // Wildcard read for ANY object under a trip's namespace. Two reasons:
    //   1. listAll(prefix) needs a matching `read` rule on the prefix — the
    //      cascade-delete in tripService.purgeStorageFolder recursively
    //      lists `trips/{tripId}/`, `trips/{tripId}/bookings/`, etc., and
    //      none of those paths match the leaf-file rules below. Without
    //      this wildcard the cascade hits 403 on the very first listAll.
    //   2. Future entities that store files under `/trips/{tripId}/...`
    //      get the membership read for free without another rule edit.
    // Writes are NOT covered here — create/update/delete must still match
    // the specific rules below (which gate by role + content-type + size).
    match /trips/{tripId}/{allPaths=**} {
      allow read: if isMember(tripId);
    }

    match /trips/{tripId}/bookings/{bookingId}/{fileName} {
      allow read: if isMember(tripId);
      // create flows through Worker-issued intents. intentMatches is
      // the STABLE-GATE side: it verifies CLAIMED metadata internal
      // consistency (size ≤ 5MB, contentType in allowlist, schema
      // shape, tripId/entityType/entityId metadata match the URL).
      // It does NOT verify that an intent doc with this id actually
      // exists, is unused, has not expired, or was minted for this
      // exact path -- /booking-file-create / /booking-file-update on
      // the Worker are the authoritative gates for those (see the
      // long block above).
      // canWriteFiles + tripNotDeleting still gate at upload time so
      // a stale 30-min intent can't be replayed by a since-demoted /
      // removed member or against a trip that's mid-cascade. update
      // is rejected -- intents are one-shot; replace flows via a new
      // intent.
      allow create: if canWriteFiles(tripId)
                    && tripNotDeleting(tripId)
                    && intentMatches(tripId, 'booking', bookingId);
      allow update: if false;
      // delete unchanged. `request.resource` is null for delete
      // operations, so a write rule referencing size / contentType
      // would deny removals (the original "image removed but save
      // fails" bug). Role gate still applies. NOTE no tripNotDeleting
      // here: delete during cascade is the same outcome as cascade
      // itself doing the delete, just a few ms earlier -- benign.
      allow delete: if canWriteFiles(tripId);
    }

    // Wish cover images. Any member can READ (gallery). CREATE goes
    // through Worker-issued intents; the wish proposer is gated at
    // the Worker (intent mint + finalize, both with Admin SDK reads
    // that don't race). DELETE stays proposer-or-owner gated here
    // because the wish doc is no longer fresh by the time anyone
    // deletes a cover. Image-only with the 5MB cap.
    match /trips/{tripId}/wishes/{wishId}/{fileName} {
      allow read: if isMember(tripId);
      // create via intent. isMember + tripNotDeleting are the upload-
      // time permission checks (the intent was minted up to 30 min
      // ago; a since-removed member or trip mid-cascade must still
      // be rejected here). intentMatches enforces stable claimed-
      // metadata properties only -- size / contentType allowlist /
      // metadata shape / tripId-entityType-entityId match + uploader
      // uid match. Intent existence / status / expires / single-use
      // is the Worker's job at /wish-file-create / /wish-file-update.
      // Proposer enforcement is at the Worker: /upload-intents refuses
      // to mint for non-proposer (Admin SDK read), and the wish-file
      // endpoints refuse to write wish.image for non-proposer. Wish-
      // specific image-only
      // enforcement happens at intent-mint time in upload-intent.ts's
      // WISH allowlist (PDF kind is rejected before the intent is
      // even created), so by the time the upload lands here, a wish-
      // bound intentId can only legitimately come from an image mint.
      //
      // Storage rules used to call isWishProposer here as defense-in-
      // depth. Production 2026-05-26: systematic 403 because the wish
      // doc is milliseconds old at upload time and the cross-service
      // read raced. Removed -- see the long comment on the
      // isWishProposer helper above.
      allow create: if isMember(tripId)
                    && tripNotDeleting(tripId)
                    && intentMatches(tripId, 'wish', wishId);
      allow update: if false;
      // Delete: proposer cleans up their own; OR trip owner
      // moderates (mirrors firestore.rules wish delete which allows
      // `proposedBy == uid() || isTripOwner(tripId)`). BOTH branches
      // require the wish doc to still exist -- the proposer check
      // does this implicitly via `isWishProposer`, and the owner
      // branch requires it explicitly. Orphan blobs (rare: process
      // crash between createWish setDoc and uploadWishImage) are
      // cleaned by the orphan-purge cron's verify-before-delete via
      // the `_purges` queue, NOT via a wide-open owner-delete rule
      // here. Emergency manual cleanup still works via Firebase
      // Console (admin auth bypasses rules entirely).
      allow delete: if isMember(tripId) && (
                      isWishProposer(tripId, wishId)
                      || (isTripOwnerStorage(tripId)
                          && firestore.exists(wishPath(tripId, wishId)))
                    );
    }

    // Expense receipts. Same canWrite gate as bookings (only owner /
    // editor mutate). Accepts image + PDF — some online receipts come
    // as PDFs and we want OCR to be able to ingest either.
    match /trips/{tripId}/expenses/{expenseId}/{fileName} {
      allow read: if isMember(tripId);
      // create via intent. canWriteFiles + tripNotDeleting are the
      // upload-time permission checks; intentMatches enforces stable
      // claimed-metadata properties (size / mime / metadata shape /
      // tripId-entityType-entityId match). Actual intent existence /
      // status / expires / path-exact / single-use binding is enforced
      // by the Worker when it consumes the intent in /expense-create
      // (post-OCR) or /expense-update (manual edit) — see the long
      // block above.
      allow create: if canWriteFiles(tripId)
                    && tripNotDeleting(tripId)
                    && intentMatches(tripId, 'expense', expenseId);
      allow update: if false;
      allow delete: if canWriteFiles(tripId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
