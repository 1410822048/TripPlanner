rules_version = '2';

// TripMate Storage access model:
//   - All booking attachments live under /trips/{tripId}/bookings/{bookingId}/{filename}.
//   - Membership is the gate: only members of the trip may read/write.
//   - Membership lookup uses the cross-service firestore.exists() against
//     the `(default)` Firestore database. Cloud Storage rules currently
//     ONLY support `(default)`; named databases would silently always
//     return false. Reference:
//     https://firebase.google.com/docs/rules/cross-service
//   - Each upload is capped at 5MB and restricted to image/* or PDF.
//   - Default deny at the bottom catches anything outside /trips/.
//
// IAM DEPENDENCY (cross-service Firestore reads):
//   `firestore.exists` / `firestore.get` from this ruleset are executed
//   under the **Cloud Storage for Firebase service agent**
//   `service-{projectNumber}@gcp-sa-firebasestorage.iam.gserviceaccount.com`
//   (NOT the end-user, NOT the firebase-rules agent). Firebase auto-
//   provisions the required role on first Console save -- but **only
//   with a CEL Condition scoped to the path prefixes the rule referenced
//   at that moment**, and `firebase deploy --only storage` from CLI does
//   NOT re-trigger the grant flow.
//
//   That means: any time we add a NEW TOP-LEVEL collection to a
//   cross-service read here, the existing Condition does not cover it
//   and reads silently return false -> rule denies -> 403 with no useful
//   log.
//
//   Phase 3.5 (2026-05-24) hit this hard: `uploadIntents/` was added as
//   a top-level collection and the auto-grant Condition (scoped to
//   `trips/*` from Phase 1) never widened. All expense / booking / wish
//   uploads 403'd in prod despite Worker + client + rules being correct.
//
//   Fix: intents now live UNDER `trips/{tripId}/uploadIntents/{id}` so
//   the cross-service read path falls inside the existing `trips/*`
//   Condition scope. No new IAM grant needed when adding intent-style
//   subcollections under `trips/*` going forward.
//
//   If a NET-NEW top-level collection is ever added and a subcollection
//   refactor is not feasible: in Cloud Console IAM, grant the Cloud
//   Storage for Firebase service agent
//   (`service-{projectNumber}@gcp-sa-firebasestorage.iam.gserviceaccount.com`)
//   the role `roles/firebaserules.firestoreServiceAgent` ("Firebase
//   Rules Firestore Service Agent") WITHOUT a path Condition. That role
//   is the narrower / preferred option -- its single permission
//   `datastore.entities.get` is exactly what Storage rules need;
//   `roles/datastore.viewer` is a broader fallback.
//   Ref: https://firebase.google.com/docs/storage/security/rules-conditions

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    // Role-aware membership: read is open to any member; create/update/
    // delete require editor or owner. Mirrors the canWrite() gate in
    // firestore.rules so the two services agree on who can mutate trip
    // data — previously Storage was looser (any member could write),
    // letting a viewer theoretically POST attachments via the raw API
    // even though the UI hides the button.
    function memberDoc(tripId) {
      return /databases/(default)/documents/trips/$(tripId)/members/$(request.auth.uid);
    }
    function tripDoc(tripId) {
      return /databases/(default)/documents/trips/$(tripId);
    }
    function isMember(tripId) {
      return isSignedIn() && firestore.exists(memberDoc(tripId));
    }
    function canWriteFiles(tripId) {
      return isSignedIn()
        && firestore.get(memberDoc(tripId)).data.role in ['owner', 'editor'];
    }
    // Cross-service mirror of firestore.rules' tripNotDeleting helper.
    // The Worker's /cascade-trip-delete sets `trip.deletingAt` BEFORE
    // anything else; this gate ensures any in-flight Storage upload on
    // another device is rejected the same way Firestore creates are.
    // Without this, an upload that lands between the Worker's Storage
    // purge and trip-doc delete steps would survive the cascade and
    // become an orphan blob (Firestore create blocked → no
    // expense/booking/wish doc referencing it → no path back to it
    // from the UI, but bytes keep billing).
    function tripNotDeleting(tripId) {
      return !('deletingAt' in firestore.get(tripDoc(tripId)).data);
    }

    // Wish cover Storage ownership: only the wish proposer can
    // write / replace / delete cover bytes. firestore.rules already
    // restricts wish doc content edits to the proposer; Storage now
    // mirrors that. wishService.createWish is doc-first: setDoc the
    // wish (without image), then upload, then updateDoc to patch
    // the image field. By the time Storage write fires, the wish
    // doc exists and its proposedBy is queryable -- no first-upload
    // exception needed, no race window.
    function wishPath(tripId, wishId) {
      return /databases/(default)/documents/trips/$(tripId)/wishes/$(wishId);
    }
    function isWishProposer(tripId, wishId) {
      return firestore.exists(wishPath(tripId, wishId))
          && firestore.get(wishPath(tripId, wishId)).data.proposedBy == request.auth.uid;
    }
    // Cross-service trip-owner check. Mirrors firestore.rules
    // `isTripOwner` so the wish delete rule can match firestore.rules'
    // moderation disjunction (proposer OR trip owner). Without this
    // Storage stays proposer-only and the owner-moderation path on
    // Firestore orphans cover blobs (Firestore doc deletes, Storage
    // returns 403, frontend swallows the Storage error → bytes leak).
    function isTripOwnerStorage(tripId) {
      return isSignedIn()
          && firestore.get(tripDoc(tripId)).data.ownerId == request.auth.uid;
    }

    // Phase 3.5 upload metadata verification. Every entity upload must
    // carry an uploadIntentId + the Worker-owned metadata shape minted
    // by /upload-intents. Storage rules validate stable properties only:
    // current auth, trip write access, path-bound metadata, size, and
    // coarse content-type allowlists.
    //
    // Do NOT read the just-created uploadIntent doc here. In production,
    // the client immediately uploads after /upload-intents returns, and
    // Storage rules' cross-service firestore.exists/get can fail that
    // read-after-write window even though the doc is already visible via
    // Firestore REST. Intent existence/status/expires/path exactness is
    // instead enforced when the Worker consumes the intent in
    // /upload-finalize, /expense-create, or /expense-update.
    //
    // Why intent + immediate-permission BOTH: the intent was minted
    // up to 30 min ago. During that window the user could be
    // demoted, removed from the trip, or the trip could enter
    // deletingAt cascade. The rules layer's role / membership /
    // tripNotDeleting checks run at upload time, so a stale-permission
    // capability token can't slip through. Intent narrows what they
    // can do; role check confirms they still can.
    function imageContentType() {
      return request.resource.contentType in [
        'image/webp',
        'image/jpeg',
        'image/png',
        'image/heic',
        'image/heif',
      ];
    }
    function uploadContentTypeOk(entityType) {
      return (
          request.resource.metadata.kind == 'pdf'
          && entityType != 'wish'
          && request.resource.contentType == 'application/pdf'
        ) || (
          request.resource.metadata.kind in ['full', 'thumb']
          && imageContentType()
        );
    }
    function intentMatches(tripId, entityType, entityId) {
      return isSignedIn()
        && 'uploadIntentId' in request.resource.metadata
        && request.resource.metadata.uploadIntentId is string
        && request.resource.metadata.uploadIntentId.size() == 32
        && request.resource.size <= 5 * 1024 * 1024
        && uploadContentTypeOk(entityType)
        && request.resource.metadata.uploaderUid == request.auth.uid
        && request.resource.metadata.tripId == tripId
        && request.resource.metadata.entityType == entityType
        && request.resource.metadata.entityId == entityId
        && request.resource.metadata.schemaVersion == 'v1';
    }

    // Wildcard read for ANY object under a trip's namespace. Two reasons:
    //   1. listAll(prefix) needs a matching `read` rule on the prefix — the
    //      cascade-delete in tripService.purgeStorageFolder recursively
    //      lists `trips/{tripId}/`, `trips/{tripId}/bookings/`, etc., and
    //      none of those paths match the leaf-file rules below. Without
    //      this wildcard the cascade hits 403 on the very first listAll.
    //   2. Future entities that store files under `/trips/{tripId}/...`
    //      get the membership read for free without another rule edit.
    // Writes are NOT covered here — create/update/delete must still match
    // the specific rules below (which gate by role + content-type + size).
    match /trips/{tripId}/{allPaths=**} {
      allow read: if isMember(tripId);
    }

    match /trips/{tripId}/bookings/{bookingId}/{fileName} {
      allow read: if isMember(tripId);
      // create flows through Worker-issued intents. intentMatches
      // verifies size, contentType, customMetadata schema, AND that
      // the upload is landing at the path the Worker minted -- so
      // the inline size / mime checks the old rule had are now
      // expressed once, at intent-mint time, with the per-entity
      // allowlist that lives in upload-intent.ts. canWriteFiles +
      // tripNotDeleting still gate at upload time so a stale 30-min
      // intent can't be replayed by a since-demoted / removed member
      // or against a trip that's mid-cascade. update is rejected --
      // intents are one-shot; replace flows via a new intent.
      allow create: if canWriteFiles(tripId)
                    && tripNotDeleting(tripId)
                    && intentMatches(tripId, 'booking', bookingId);
      allow update: if false;
      // delete unchanged. `request.resource` is null for delete
      // operations, so a write rule referencing size / contentType
      // would deny removals (the original "image removed but save
      // fails" bug). Role gate still applies. NOTE no tripNotDeleting
      // here: delete during cascade is the same outcome as cascade
      // itself doing the delete, just a few ms earlier -- benign.
      allow delete: if canWriteFiles(tripId);
    }

    // Wish cover images. Any member can READ (gallery), but write /
    // replace / delete is restricted to the wish proposer. The
    // wishService.createWish flow is doc-first so the wish doc
    // exists by the time Storage write fires. Image-only with the
    // 5MB cap.
    match /trips/{tripId}/wishes/{wishId}/{fileName} {
      allow read: if isMember(tripId);
      // create via intent. isMember + tripNotDeleting + isWishProposer
      // are the upload-time permission checks (the intent was minted
      // earlier so a since-changed proposer or membership status must
      // still pass here). intentMatches handles size / mime / metadata
      // schema. Wish intents always require image content type, but
      // that's enforced upstream by upload-intent.ts's WISH allowlist.
      allow create: if isMember(tripId)
                    && tripNotDeleting(tripId)
                    && isWishProposer(tripId, wishId)
                    && intentMatches(tripId, 'wish', wishId);
      allow update: if false;
      // Delete: proposer cleans up their own; OR trip owner
      // moderates (mirrors firestore.rules wish delete which allows
      // `proposedBy == uid() || isTripOwner(tripId)`). BOTH branches
      // require the wish doc to still exist -- the proposer check
      // does this implicitly via `isWishProposer`, and the owner
      // branch requires it explicitly. Orphan blobs (rare: process
      // crash between createWish setDoc and uploadWishImage) are
      // cleaned by the orphan-purge cron's verify-before-delete via
      // the `_purges` queue, NOT via a wide-open owner-delete rule
      // here. Emergency manual cleanup still works via Firebase
      // Console (admin auth bypasses rules entirely).
      allow delete: if isMember(tripId) && (
                      isWishProposer(tripId, wishId)
                      || (isTripOwnerStorage(tripId)
                          && firestore.exists(wishPath(tripId, wishId)))
                    );
    }

    // Expense receipts. Same canWrite gate as bookings (only owner /
    // editor mutate). Accepts image + PDF — some online receipts come
    // as PDFs and we want OCR to be able to ingest either.
    match /trips/{tripId}/expenses/{expenseId}/{fileName} {
      allow read: if isMember(tripId);
      // create via intent. canWriteFiles + tripNotDeleting are the
      // upload-time permission checks; intentMatches handles size /
      // mime / metadata schema / path binding.
      allow create: if canWriteFiles(tripId)
                    && tripNotDeleting(tripId)
                    && intentMatches(tripId, 'expense', expenseId);
      allow update: if false;
      allow delete: if canWriteFiles(tripId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
