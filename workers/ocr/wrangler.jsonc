{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "tripmate-ocr",
	"main": "src/index.ts",
	"compatibility_date": "2026-07-02",
	"compatibility_flags": ["nodejs_compat"],
	"observability": { "enabled": true },
	"upload_source_maps": true,
	// Keep the public *.workers.dev URL (frontend calls it).
	"workers_dev": true,
	// Disable per-version preview URLs — we don't do gradual rollouts,
	// so the extra attack surface isn't worth it.
	"preview_urls": false,
	// Non-secret env. Hardcoded here — Firebase project ID isn't sensitive
	// (it's literally part of every signed-in user's JWT issuer claim) and
	// the CORS allowlist needs to be readable for debugging.
	"vars": {
		"FIREBASE_PROJECT_ID": "tripplanner-80a4f",
		// Firebase Storage bucket — used by trip-cascade (Storage purge)
		// and receipt-purge cron. Single source of truth; if the project
		// ever moves bucket, this is the only line to update.
		"FIREBASE_STORAGE_BUCKET": "tripplanner-80a4f.firebasestorage.app",
		"ALLOWED_ORIGINS": "https://tripmate-2wg.pages.dev,*.tripmate-2wg.pages.dev,http://localhost:5173,http://127.0.0.1:5173",
		// Sentry DSN — same project as the frontend (VITE_SENTRY_DSN in
		// the SPA bundle). Public key in a DSN is not a secret (frontend
		// ships it in plaintext); ingest endpoint accepts events from
		// any source matching the project. `server_name: 'tripmate-ocr'`
		// inside the envelope (see sentry.ts) lets us filter Worker
		// events from frontend events in the Sentry UI. Empty string
		// disables telemetry cleanly (sentry.ts parseDsn returns null).
		"SENTRY_DSN": "",
		// Claude OCR via Microsoft Foundry (Azure AI Foundry). Non-secret:
		// the resource name is a URL host component (not a credential) and the
		// deployment name is a routing label. The API key is a SECRET
		// (ANTHROPIC_FOUNDRY_API_KEY via `wrangler secret put`).
		// Endpoint = https://{RESOURCE}.services.ai.azure.com/anthropic/v1/messages
		//   RESOURCE:   Foundry resource name (East US2 / Sweden Central only).
		//   DEPLOYMENT: the Claude deployment name in the Foundry portal. Now
		//               Sonnet 4.6 (Haiku 4.5 read receipt amounts poorly). Swap
		//               tier = change this one var to that deployment's name.
		"ANTHROPIC_FOUNDRY_RESOURCE": "aic-claude-eus2",
		"CLAUDE_DEPLOYMENT": "claude-sonnet-5",
		// Booking PDF import is text/layout extraction, not receipt OCR; Haiku
		// is the faster default here. Leave CLAUDE_DEPLOYMENT on Sonnet so the
		// receipt fallback path keeps its higher-accuracy model.
		"BOOKING_CLAUDE_DEPLOYMENT": "claude-haiku-4-5-2",
		// Qwen OCR provider. API key is a SECRET (QWEN_API_KEY via
		// `wrangler secret put`). Required whenever OCR_PRIMARY_PROVIDER or
		// OCR_FALLBACK_PROVIDER is qwen; /ocr-compare also uses it when enabled.
		// This uses Alibaba Cloud Model Studio Singapore's workspace-scoped
		// OpenAI-compatible endpoint; the older dashscope-intl.aliyuncs.com
		// domain is legacy.
		"QWEN_BASE_URL": "https://ws-g7wwlr6k1kgzbizw.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1",
		"QWEN_MODEL": "qwen3.6-flash",
		// Clean OCR routing:
		//   /ocr                     -> OCR_PRIMARY_PROVIDER
		//   /ocr-fallback            -> OCR_FALLBACK_PROVIDER
		//   /ocr-compare             -> only when OCR_COMPARE_ENABLED=true
		// Default product path is Qwen because receipt preprocessing made it
		// faster with acceptable quality; Claude remains an explicit backup.
		"OCR_PRIMARY_PROVIDER": "qwen",
		"OCR_FALLBACK_PROVIDER": "claude",
		"OCR_COMPARE_ENABLED": "false"
	},
	// Two independent schedules — index.ts's scheduled() branches on
	// event.cron so neither ever runs the other's jobs:
	//   "0 3 * * *"    daily UTC 03:00 maintenance (receipt/orphan purge +
	//                  storage-maintenance + upload-intent purge).
	//                  Scoped to ~14min via SOFT_DEADLINE_MS in
	//                  receipt-purge.ts; under the 15-min hard cap on
	//                  Workers scheduled handlers.
	//   "*/5 * * * *"  Wish-deadline sweep (wish-deadline-sweep.ts) —
	//                  needs minute-granularity since deadlines are
	//                  arbitrary owner-set timestamps, not daily-aligned.
	"triggers": {
		"crons": ["0 3 * * *", "*/5 * * * *"]
	},
	// Per-uid rate limiting (GA 2025-09). Counters are per Cloudflare
	// location (eventually consistent) — fine for abuse prevention,
	// not a hard quota. namespace_id is account-scoped and arbitrary
	// (just unique); we use 1001-1005 to keep human-readable.
	//   /ocr                  expensive path (OCR provider quota)      → 30/min
	//   membership endpoints  rare server-heavy writes               → 5/min
	//   /cascade-trip-delete  HEAVY (full trip cascade + storage)    → 1/min
	//                         tighter than member cascade because
	//                         trip-delete touches O(100) docs +
	//                         dozens of Storage objects per call.
	//   /expense-*            user-driven form writes                 → 30/min
	//   /settlement-*         user-driven, rare event (a few/trip)    → 5/min
	//                         settlement create runs a full pairwise
	//                         debt computation (tx + runQuery x 2);
	//                         tighter cap reflects "this is a clicked
	//                         button, not a typed-keystroke flow".
	//   /attachment-*-url[s]  signed-URL minting (local RSA sign,      → 120/min
	//                         no OCR / no Firestore write). Looser:
	//                         a list screen issues a few thumb batches.
	//   /route-*               search / preview / write use separate
	//                         counters so autocomplete cannot starve apply.
	"ratelimits": [
		{
			"name": "OCR_RATE_LIMITER",
			"namespace_id": "1001",
			"simple": { "limit": 30, "period": 60 }
		},
		{
			"name": "CASCADE_RATE_LIMITER",
			"namespace_id": "1002",
			"simple": { "limit": 5, "period": 60 }
		},
		{
			"name": "TRIP_CASCADE_RATE_LIMITER",
			"namespace_id": "1003",
			"simple": { "limit": 1, "period": 60 }
		},
		{
			"name": "EXPENSE_RATE_LIMITER",
			"namespace_id": "1004",
			"simple": { "limit": 30, "period": 60 }
		},
		{
			"name": "SETTLEMENT_RATE_LIMITER",
			"namespace_id": "1005",
			"simple": { "limit": 5, "period": 60 }
		},
		{
			"name": "ATTACHMENT_URL_RATE_LIMITER",
			"namespace_id": "1006",
			"simple": { "limit": 120, "period": 60 }
		},
		{
			"name": "ROUTE_SEARCH_RATE_LIMITER",
			"namespace_id": "1007",
			"simple": { "limit": 60, "period": 60 }
		},
		{
			"name": "ROUTE_PREVIEW_RATE_LIMITER",
			"namespace_id": "1008",
			"simple": { "limit": 10, "period": 60 }
		},
		{
			"name": "ROUTE_WRITE_RATE_LIMITER",
			"namespace_id": "1009",
			"simple": { "limit": 10, "period": 60 }
		}
	],
	// Durable Object for cross-PoP rate limiting. Each instance is
	// keyed by uid (`idFromName(uid)`); cold-instantiated on first
	// hit, idle instances cost nothing. SQLite storage class — the
	// modern default; old key-value storage is legacy.
	"durable_objects": {
		"bindings": [
			{
				"name": "GLOBAL_LIMITER",
				"class_name": "GlobalRateLimiter"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["GlobalRateLimiter"]
		}
	]
	// Secrets are set via `wrangler secret put`:
	//   ANTHROPIC_FOUNDRY_API_KEY ← Microsoft Foundry (Azure AI Foundry) Claude API key
	//   QWEN_API_KEY               ← Qwen/OpenAI-compatible provider API key
	//   FIREBASE_SERVICE_ACCOUNT  ← service account JSON for Firestore/GCS admin REST
	//   GEOAPIFY_API_KEY           ← place autocomplete / geocoding
	//   ORS_API_KEY                ← walking matrix + final walking geometry
	//   ROUTE_PREVIEW_HMAC_SECRET  ← signs preview/apply payloads
}
